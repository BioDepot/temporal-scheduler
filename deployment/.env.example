POSTGRES_PASSWORD=temporal
POSTGRES_USER=temporal
POSTGRESQL_VERSION=13
ELASTICSEARCH_VERSION=7.17.10
TEMPORAL_VERSION=1.25.2
TEMPORAL_ADMIN_TOOLS_VERSION=1.25.2-tctl-1.18.1-cli-1.1.2
TEMPORAL_UI_VERSION=2.34.0

MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

WORKER_RAM=16000MB
WORKER_CPUS=8
WORKER_GPUS=0

# Host path mounted into the scheduler and worker containers.
SCHED_STORAGE_DIR=/tmp/temporal-scheduler-bench

# Optional extra Singularity/Docker binds for job commands (semicolon-separated
# host_path:container_path[:ro]). Worker containers must mount each host_path at
# the same path inside the container (e.g. docker volume /storage:/storage) so
# singularity exec can pass them through. Example for STAR genome indices:
# BWB_SINGULARITY_EXTRA_BINDS=/storage:/storage

# Host port for the Go SLURM backend sidecar.
# local_slurm_test_env_up.sh will auto-shift this if 8765 is already taken.
GO_SLURM_HOST_PORT=8765
