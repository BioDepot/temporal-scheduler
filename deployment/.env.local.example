POSTGRES_PASSWORD=temporal
POSTGRES_USER=temporal
POSTGRESQL_VERSION=13
ELASTICSEARCH_VERSION=7.17.10
TEMPORAL_VERSION=1.25.2
TEMPORAL_ADMIN_TOOLS_VERSION=1.25.2-tctl-1.18.1-cli-1.1.2
TEMPORAL_UI_VERSION=2.34.0

MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_ENDPOINT_URL=http://minio:9000

# Keep this host path identical inside worker containers. The local Docker
# worker talks to the host Docker daemon, so nested job containers must see the
# same absolute path on the host.
SCHED_STORAGE_DIR=/tmp/temporal-scheduler-local

BWB_SCHEDULER_IMAGE=bwb-scheduler:local
LOCAL_WORKER_QUEUE=worker1
WORKER_RAM=4096MB
WORKER_CPUS=2
WORKER_GPUS=0

TEMPORAL_GRPC_PORT=7233
TEMPORAL_UI_PORT=8080
SCHEDULER_API_PORT=8000
BWB_SINGULARITY_EXTRA_BINDS=
